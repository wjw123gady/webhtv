<?xml version="1.0" encoding="utf-8"?>
<com.fongmi.android.tv.ui.custom.ProgressLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/progressLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.fongmi.android.tv.ui.custom.ContextWallImageView
        android:id="@+id/contextWall"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:importantForAccessibility="no"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/video"
        android:layout_width="400dp"
        android:layout_height="225dp"
        android:layout_margin="24dp"
        android:background="@color/black"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:foreground="@drawable/selector_video"
        android:nextFocusLeft="@id/video"
        android:nextFocusRight="@id/content"
        android:nextFocusUp="@id/video"
        android:nextFocusDown="@id/flag">

        <androidx.media3.ui.PlayerView
            android:id="@+id/exo"
            style="@style/Player.Vod"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:surface_type="none" />

        <FrameLayout
            android:id="@+id/audioStage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_audio_player_background"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="44dp"
            android:paddingTop="20dp"
            android:paddingEnd="44dp"
            android:paddingBottom="14dp"
            android:visibility="gone"
            tools:visibility="visible">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:orientation="vertical">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:clipChildren="false"
                    android:clipToPadding="false"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="252dp"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical">

                        <FrameLayout
                            android:id="@+id/audioDisc"
                            android:layout_width="174dp"
                            android:layout_height="174dp"
                            android:background="@drawable/shape_audio_disc_back"
                            android:padding="11dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:id="@+id/audioCover"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/artwork"
                                app:shapeAppearanceOverlay="@style/ShapeAppearance.WebHTV.AudioCover"
                                app:strokeColor="@color/white_20"
                                app:strokeWidth="1dp" />

                        </FrameLayout>

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioTitle"
                            style="@style/Video.ContextText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="2"
                            android:textColor="@color/white"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            tools:text="八段锦口令音乐" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioSubtitle"
                            style="@style/Video.ContextText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:ellipsize="end"
                            android:gravity="center"
                            android:maxLines="1"
                            android:textColor="@color/white_70"
                            android:textSize="14sp"
                            tools:text="站源 · 当前播放列表" />

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/audioBadges"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:visibility="gone">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioBadgeFormat"
                                style="@style/Video.ContextText"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:background="@drawable/shape_audio_badge"
                                android:gravity="center"
                                android:minWidth="58dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:text="@string/player_audio_badge_audio"
                                android:textColor="@color/white_90"
                                android:textSize="13sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioBadgeLyrics"
                                style="@style/Video.ContextText"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/shape_audio_badge"
                                android:gravity="center"
                                android:minWidth="58dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:text="@string/player_audio_badge_lyrics"
                                android:textColor="@color/white_90"
                                android:textSize="13sp" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioBadgeQueue"
                                style="@style/Video.ContextText"
                                android:layout_width="wrap_content"
                                android:layout_height="28dp"
                                android:layout_marginStart="8dp"
                                android:background="@drawable/shape_audio_badge"
                                android:gravity="center"
                                android:minWidth="58dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:text="@string/player_audio_badge_queue"
                                android:textColor="@color/white_90"
                                android:textSize="13sp" />

                        </androidx.appcompat.widget.LinearLayoutCompat>

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginStart="34dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.fongmi.android.tv.ui.custom.LyricsOverlayView
                            android:id="@+id/audioLyrics"
                            android:layout_width="match_parent"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.fongmi.android.tv.ui.custom.KaraokeStatusView
                            android:id="@+id/audioKaraoke"
                            android:layout_width="match_parent"
                            android:layout_height="96dp"
                            android:layout_marginTop="8dp" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/audioPlaybackPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical">

                    <com.fongmi.android.tv.ui.custom.CustomSeekView
                        android:id="@+id/audioSeek"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="72dp"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/audioTransport"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/audioRepeatAction"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:padding="8dp"
                                    android:scaleType="center"
                                    android:src="@drawable/ic_audio_repeat" />

                                <com.google.android.material.textview.MaterialTextView
                                    style="@style/Video.ContextText"
                                    android:layout_width="match_parent"
                                    android:layout_height="18dp"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="@string/player_audio_repeat"
                                    android:textColor="@color/white_80"
                                    android:textSize="12sp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/audioPrev"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:padding="8dp"
                                    android:scaleType="center"
                                    android:src="@drawable/exo_icon_previous" />

                                <com.google.android.material.textview.MaterialTextView
                                    style="@style/Video.ContextText"
                                    android:layout_width="match_parent"
                                    android:layout_height="18dp"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="@string/play_prev"
                                    android:textColor="@color/white_80"
                                    android:textSize="12sp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/audioPlay"
                                    android:layout_width="44dp"
                                    android:layout_height="44dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:padding="8dp"
                                    android:scaleType="center"
                                    android:src="@drawable/exo_icon_play" />

                                <com.google.android.material.textview.MaterialTextView
                                    style="@style/Video.ContextText"
                                    android:layout_width="match_parent"
                                    android:layout_height="18dp"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="@string/play"
                                    android:textColor="@color/white_80"
                                    android:textSize="12sp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/audioNext"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:padding="8dp"
                                    android:scaleType="center"
                                    android:src="@drawable/exo_icon_next" />

                                <com.google.android.material.textview.MaterialTextView
                                    style="@style/Video.ContextText"
                                    android:layout_width="match_parent"
                                    android:layout_height="18dp"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="@string/play_next"
                                    android:textColor="@color/white_80"
                                    android:textSize="12sp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:gravity="center"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.AppCompatImageView
                                    android:id="@+id/audioQueueAction"
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="?attr/selectableItemBackgroundBorderless"
                                    android:padding="8dp"
                                    android:scaleType="center"
                                    android:src="@drawable/ic_audio_queue" />

                                <com.google.android.material.textview.MaterialTextView
                                    style="@style/Video.ContextText"
                                    android:layout_width="match_parent"
                                    android:layout_height="18dp"
                                    android:gravity="center"
                                    android:singleLine="true"
                                    android:text="@string/player_audio_playlist"
                                    android:textColor="@color/white_80"
                                    android:textSize="12sp" />

                            </androidx.appcompat.widget.LinearLayoutCompat>

                        </androidx.appcompat.widget.LinearLayoutCompat>

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:id="@+id/audioActionRow"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioLyricsAction"
                                style="@style/AudioActionButton"
                                android:layout_marginEnd="4dp"
                                android:text="@string/player_lyrics_search"
                                android:textSize="12sp"
                                app:drawableTopCompat="@drawable/ic_audio_lyrics" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioKaraokeAction"
                                style="@style/AudioActionButton"
                                android:layout_marginEnd="4dp"
                                android:text="@string/player_karaoke_mode"
                                android:textSize="12sp"
                                app:drawableTopCompat="@drawable/ic_action_ktv" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/audioMoreAction"
                                style="@style/AudioActionButton"
                                android:text="@string/player_audio_more"
                                android:textSize="12sp"
                                app:drawableTopCompat="@drawable/ic_audio_more" />

                        </androidx.appcompat.widget.LinearLayoutCompat>

                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/audioToolRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioCastAction"
                            style="@style/VideoActionButton"
                            android:layout_marginEnd="4dp"
                            android:text="@string/play_cast"
                            app:drawableTopCompat="@drawable/ic_control_cast_shadow" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioKeepAction"
                            style="@style/VideoActionButton"
                            android:layout_marginEnd="4dp"
                            android:text="@string/keep"
                            app:drawableTopCompat="@drawable/ic_action_keep" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioSettingAction"
                            style="@style/VideoActionButton"
                            android:layout_marginEnd="4dp"
                            android:text="@string/nav_setting"
                            app:drawableTopCompat="@drawable/ic_control_setting_shadow" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioTrackAction"
                            style="@style/VideoActionButton"
                            android:layout_marginEnd="4dp"
                            android:text="@string/play_track_audio"
                            app:drawableTopCompat="@drawable/ic_action_audio" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioSubtitleAction"
                            style="@style/VideoActionButton"
                            android:layout_marginEnd="4dp"
                            android:text="@string/play_track_text"
                            app:drawableTopCompat="@drawable/ic_action_subtitle" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/audioInfoAction"
                            style="@style/VideoActionButton"
                            android:text="@string/player_osd"
                            app:drawableTopCompat="@drawable/ic_control_info" />

                    </androidx.appcompat.widget.LinearLayoutCompat>

                </androidx.appcompat.widget.LinearLayoutCompat>

            </androidx.appcompat.widget.LinearLayoutCompat>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/audioBackgroundAction"
                android:layout_width="98dp"
                android:layout_height="150dp"
                android:layout_gravity="top|end"
                android:layout_marginEnd="-28dp"
                android:background="@null"
                android:contentDescription="@string/player_audio_background"
                android:padding="0dp"
                android:scaleType="fitXY"
                android:src="@drawable/audio_background_drip" />

        </FrameLayout>

        <include
            android:id="@+id/widget"
            layout="@layout/view_widget_vod"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.fongmi.android.tv.ui.custom.LyricsOverlayView
            android:id="@+id/lyrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.fongmi.android.tv.ui.custom.KaraokeStatusView
            android:id="@+id/karaoke"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp" />

        <include
            android:id="@+id/control"
            layout="@layout/view_control_vod"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:visibility="gone" />

        <include
            android:id="@+id/progress"
            layout="@layout/view_progress"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <include
            android:id="@+id/osd"
            layout="@layout/view_player_osd"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.fongmi.android.tv.ui.custom.LutQuickPanel
            android:id="@+id/lutQuick"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/name"
        style="@style/Video.ContextText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginEnd="24dp"
        android:layout_toEndOf="@+id/video"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="24sp"
        tools:text="慶餘年第二季" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/remark"
        style="@style/Video.ContextText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/name"
        android:layout_alignStart="@+id/name"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="16sp"
        tools:text="更新到第二季" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/row1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/remark"
        android:layout_alignStart="@+id/remark"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:orientation="horizontal">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/site"
            style="@style/Video.ContextText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:text="站源：泥巴" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/year"
            style="@style/Video.ContextText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:text="年份：2022" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/area"
            style="@style/Video.ContextText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:text="地區：台灣" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/type"
            style="@style/Video.ContextText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textColor="@color/white"
            android:textSize="16sp"
            tools:text="類型：科幻" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/director"
        style="@style/Video.ContextText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/row1"
        android:layout_alignStart="@+id/name"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:nextFocusDown="@id/actor"
        android:singleLine="true"
        android:textColor="@color/white"
        android:textSize="16sp"
        tools:text="導演：FongMi" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/actor"
        style="@style/Video.ContextText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/director"
        android:layout_alignStart="@+id/name"
        android:layout_marginTop="6dp"
        android:layout_marginEnd="24dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:nextFocusDown="@id/content"
        android:textColor="@color/white"
        android:textSize="16sp"
        tools:text="演員：FongMi" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/row2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignStart="@+id/name"
        android:layout_alignBottom="@+id/video"
        android:orientation="horizontal">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/content"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/selector_video_item"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusUp="@id/actor"
            android:nextFocusDown="@id/flag"
            android:singleLine="true"
            android:text="@string/detail_desc"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:drawableStartCompat="@drawable/ic_detail_desc" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/shortDisplay"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/selector_video_item"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusUp="@id/actor"
            android:nextFocusDown="@id/flag"
            android:singleLine="true"
            android:text="@string/play_short_display"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:drawableStartCompat="@drawable/ic_detail_short_display" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/selector_video_item"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusUp="@id/actor"
            android:nextFocusDown="@id/flag"
            android:singleLine="true"
            android:text="@string/play_search"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:drawableStartCompat="@drawable/ic_action_search" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/keep"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            android:background="@drawable/selector_video_item"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusUp="@id/actor"
            android:nextFocusDown="@id/flag"
            android:singleLine="true"
            android:text="@string/keep"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:drawableStartCompat="@drawable/ic_detail_keep_off" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/change1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/selector_video_item"
            android:drawablePadding="6dp"
            android:focusable="true"
            android:focusableInTouchMode="true"
            android:gravity="center"
            android:nextFocusRight="@id/change1"
            android:nextFocusUp="@id/actor"
            android:nextFocusDown="@id/flag"
            android:singleLine="true"
            android:text="@string/play_change"
            android:textColor="@color/white"
            android:textSize="16sp"
            app:drawableStartCompat="@drawable/ic_detail_change" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/video"
        android:layout_alignParentBottom="true"
        android:clipChildren="true"
        android:clipToPadding="true"
        android:orientation="vertical"
        android:paddingBottom="8dp">

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/flag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/quality"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone"
            tools:visibility="visible" />

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/array"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone" />

        <androidx.leanback.widget.VerticalGridView
            android:id="@+id/episode"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipChildren="true"
            android:clipToPadding="true"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="8dp"
            android:visibility="gone" />

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/part"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone" />

        <androidx.leanback.widget.HorizontalGridView
            android:id="@+id/quick"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:visibility="gone" />

    </androidx.appcompat.widget.LinearLayoutCompat>
</com.fongmi.android.tv.ui.custom.ProgressLayout>
