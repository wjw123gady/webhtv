<resources>

    <style name="Vod">
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="Vod.Grid">
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerSizeTopRight">8dp</item>
    </style>

    <style name="Vod.Grid.Large">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Vod.Circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Vod.List">
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerSizeBottomLeft">8dp</item>
    </style>

    <style name="Player">
        <item name="resize_mode">fit</item>
        <item name="use_artwork">true</item>
        <item name="use_controller">false</item>
    </style>

    <style name="Player.Vod">
        <item name="keep_content_on_player_reset">false</item>
    </style>

    <style name="Player.Live">
        <item name="keep_content_on_player_reset">true</item>
    </style>

    <style name="Video" />

    <style name="Video.ContextText">
        <item name="android:shadowColor">@color/black_90</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">3</item>
    </style>

    <style name="Shadow">
        <item name="android:shadowColor">#B0000000</item>
        <item name="android:shadowDx">1.5</item>
        <item name="android:shadowDy">1.5</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <style name="Theme.WebHTV.LightDialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@drawable/shape_shell_proxy_dialog</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:colorBackgroundFloating">@color/white</item>
        <item name="android:textColorPrimary">#202124</item>
        <item name="android:textColorSecondary">#5F6368</item>
        <item name="android:textColorHint">#8A8F98</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textCursorDrawable">@drawable/shape_cursor_dialog</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceBright">@color/white</item>
        <item name="colorSurfaceDim">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
        <item name="colorSurfaceContainerHighest">@color/white</item>
        <item name="colorSurfaceContainerLow">@color/white</item>
        <item name="colorSurfaceContainerLowest">@color/white</item>
        <item name="colorOnSurface">#202124</item>
        <item name="colorOnSurfaceVariant">#5F6368</item>
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorControlNormal">#5F6368</item>
        <item name="colorControlActivated">#1A73E8</item>
        <item name="isLightTheme">true</item>
    </style>

    <style name="ThemeOverlay.WebHTV.LightDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:colorBackground">@color/white</item>
        <item name="android:colorBackgroundFloating">@color/white</item>
        <item name="android:textColorPrimary">#202124</item>
        <item name="android:textColorSecondary">#5F6368</item>
        <item name="android:textColorHint">#8A8F98</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textCursorDrawable">@drawable/shape_cursor_dialog</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorSurfaceBright">@color/white</item>
        <item name="colorSurfaceDim">@color/white</item>
        <item name="colorSurfaceContainer">@color/white</item>
        <item name="colorSurfaceContainerHigh">@color/white</item>
        <item name="colorSurfaceContainerHighest">@color/white</item>
        <item name="colorSurfaceContainerLow">@color/white</item>
        <item name="colorSurfaceContainerLowest">@color/white</item>
        <item name="colorOnSurface">#202124</item>
        <item name="colorOnSurfaceVariant">#5F6368</item>
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorControlNormal">#5F6368</item>
        <item name="colorControlActivated">#1A73E8</item>
        <item name="isLightTheme">true</item>
    </style>

    <style name="Widget.WebHTV" parent="@android:style/Widget" />

    <style name="Widget.WebHTV.LightDialog" />

    <style name="Widget.WebHTV.LightDialog.Label">
        <item name="android:textColor">#202124</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.WebHTV.LightDialog.Helper">
        <item name="android:textColor">#5F6368</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Widget.WebHTV.LightDialog.Input">
        <item name="android:background">@drawable/selector_dialog_input</item>
        <item name="android:textColor">#202124</item>
        <item name="android:textColorHint">#666666</item>
        <item name="android:textCursorDrawable">@drawable/shape_cursor_dialog</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.WebHTV.LightDialog.Button.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textColor">@color/dialog_tonal_button_text</item>
        <item name="backgroundTint">@color/dialog_tonal_button_bg</item>
    </style>

    <style name="Widget.WebHTV.LightDialog.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textColor">@color/dialog_outlined_button_text</item>
        <item name="backgroundTint">@color/dialog_outlined_button_bg</item>
        <item name="strokeColor">@color/dialog_outlined_button_stroke</item>
    </style>

    <style name="Widget.WebHTV.LightDialog.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/dialog_text_button</item>
    </style>

    <style name="DialogFullScreen" parent="android:Theme.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:backgroundDimEnabled">true</item>
    </style>

    <style name="Control">
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
    </style>

    <style name="DisplayControl" parent="Control">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:layout_marginBottom">6dp</item>
        <item name="android:background">@drawable/selector_display_option</item>
        <item name="android:gravity">center</item>
        <item name="android:minHeight">36dp</item>
        <item name="android:minWidth">56dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textColor">@color/display_option_text</item>
        <item name="android:textSize">14sp</item>
        <item name="android:shadowColor">@color/transparent</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">0</item>
        <item name="android:shadowRadius">0</item>
    </style>

</resources>
