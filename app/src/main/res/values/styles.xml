<resources>

    <style name="Vod">
        <item name="cornerFamily">rounded</item>
    </style>

    <style name="Vod.Grid">
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerSizeTopRight">8dp</item>
    </style>

    <style name="Vod.Grid.Large">
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Vod.Circle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <style name="Vod.List">
        <item name="cornerSizeTopLeft">8dp</item>
        <item name="cornerSizeBottomLeft">8dp</item>
    </style>

    <style name="Player">
        <item name="resize_mode">fit</item>
        <item name="use_artwork">true</item>
        <item name="use_controller">false</item>
    </style>

    <style name="Player.Vod">
        <item name="keep_content_on_player_reset">false</item>
    </style>

    <style name="Player.Live">
        <item name="keep_content_on_player_reset">true</item>
    </style>

    <style name="Video" />

    <style name="Video.ContextText">
        <item name="android:shadowColor">@color/black_90</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">3</item>
    </style>

    <style name="Theme.WebHTV.LightDialog" parent="Theme.Material3.Light.Dialog.Alert">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowBackground">@color/transparent</item>
        <item name="android:colorBackground">@color/white</item>
        <item name="android:textColorPrimary">#202124</item>
        <item name="android:textColorSecondary">#5F6368</item>
        <item name="android:textColorHint">#8A8F98</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:textCursorDrawable">@drawable/shape_cursor_dialog</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">#202124</item>
        <item name="colorOnSurfaceVariant">#5F6368</item>
        <item name="colorPrimary">#1A73E8</item>
        <item name="colorControlNormal">#5F6368</item>
        <item name="colorControlActivated">#1A73E8</item>
        <item name="isLightTheme">true</item>
    </style>

    <style name="ThemeOverlay.WebHTV.LightDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:colorBackground">@color/white</item>
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">#202124</item>
        <item name="colorOnSurfaceVariant">#5F6368</item>
        <item name="colorPrimary">#1A73E8</item>
        <item name="isLightTheme">true</item>
    </style>

    <style name="TextAppearance.WebHTV.LightDialogSliderLabel" parent="TextAppearance.MaterialComponents.Tooltip">
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.WebHTV.LightDialogSliderLabel" parent="Widget.MaterialComponents.Tooltip">
        <item name="android:textAppearance">@style/TextAppearance.WebHTV.LightDialogSliderLabel</item>
        <item name="backgroundTint">#174EA6</item>
    </style>

</resources>
