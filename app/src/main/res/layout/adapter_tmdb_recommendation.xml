<?xml version="1.0" encoding="utf-8"?>
<!-- TMDB 推荐影片卡片：竖版海报 + 标题 + 评分 -->
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="120dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="12dp"
    android:background="@drawable/selector_tmdb_card"
    android:focusable="true"
    android:focusableInTouchMode="true"
    android:padding="6dp"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="108dp"
        android:layout_height="162dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/poster"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1C2530"
                android:scaleType="centerCrop"
                android:contentDescription="@null"
                tools:src="@color/black" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/recommendationTextPanel"
                android:layout_width="match_parent"
                android:layout_height="66dp"
                android:layout_gravity="bottom"
                android:background="@drawable/shape_tmdb_recommendation_info"
                android:gravity="bottom"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingBottom="8dp">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="白月光" />

            </androidx.appcompat.widget.LinearLayoutCompat>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/rating"
                android:layout_width="wrap_content"
                android:layout_height="24dp"
                android:layout_gravity="top|end"
                android:layout_margin="6dp"
                android:background="@drawable/shape_tmdb_recommendation_rating_badge"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:minWidth="42dp"
                android:paddingStart="7dp"
                android:paddingEnd="7dp"
                android:textColor="#FFD35C"
                android:textSize="11sp"
                android:textStyle="bold"
                android:visibility="gone"
                tools:text="★ 8.0"
                tools:visibility="visible" />

        </FrameLayout>

    </androidx.cardview.widget.CardView>

</androidx.appcompat.widget.LinearLayoutCompat>
