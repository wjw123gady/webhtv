<?xml version="1.0" encoding="utf-8"?>
<!--
  TMDB 风格详情头部面板。
  在 TMDB 模式下由 TmdbHeaderView 动态注入到详情页滚动区顶部。
  视觉结构（自上而下）：
  - 大背景图（backdrop）+ 渐变遮罩
  - 海报 + 标题 + 评分徽章 + 类型标签（叠在背景图底部）
  - 简介（可展开）
  - 演员横向滚动卡片
-->
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/tmdbHeaderRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:background="#0F141A">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/tmdbFusionInfoCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="#AFFFFFFF"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:strokeColor="#33424B57"
        app:strokeWidth="1dp"
        tools:visibility="visible">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="112dp"
                android:layout_height="160dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#30FFFFFF"
                app:strokeWidth="1dp">

                <ImageView
                    android:id="@+id/tmdbFusionPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="@null"
                    android:scaleType="centerCrop"
                    tools:src="@color/black" />

            </com.google.android.material.card.MaterialCardView>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbFusionTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:textColor="#12202D"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    tools:text="爱情有烟火" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbFusionSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="#CC12202D"
                    android:textSize="14sp"
                    tools:text="2026-06-15 · 评分 8.5" />

                <com.google.android.flexbox.FlexboxLayout
                    android:id="@+id/tmdbFusionMeta"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    app:flexWrap="wrap" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbFusionSource"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_marginTop="10dp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:maxLines="1"
                    android:maxWidth="220dp"
                    android:textColor="#9912202D"
                    android:textSize="12sp"
                    tools:text="当前站源：荐片[APP]" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbFusionOverview"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:ellipsize="end"
                    android:lineSpacingExtra="3dp"
                    android:maxLines="5"
                    android:textColor="#E612202D"
                    android:textSize="13sp"
                    tools:text="投行小职员钱菲，原本沉浸在对人生的幸福规划中，但没想到，未婚夫汪若海选择了不再与她同行。" />

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </com.google.android.material.card.MaterialCardView>

    <!-- 背景图 + 海报 + 标题区 -->
    <FrameLayout
        android:id="@+id/tmdbNativeHero"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/tmdbBackdrop"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:contentDescription="@null"
            tools:src="@color/black" />

        <!-- 底部渐变遮罩，让海报/文字浮在图上 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:background="@drawable/shape_tmdb_backdrop_scrim" />

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="40dp"
            android:paddingBottom="12dp">

            <androidx.cardview.widget.CardView
                android:layout_width="92dp"
                android:layout_height="138dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="6dp">

                <ImageView
                    android:id="@+id/tmdbPoster"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:contentDescription="@null"
                    tools:src="@color/black" />

            </androidx.cardview.widget.CardView>

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="2"
                    android:shadowColor="#000000"
                    android:shadowDx="0"
                    android:shadowDy="2"
                    android:shadowRadius="6"
                    android:textColor="@android:color/white"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    tools:text="仙逆" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tmdbRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/shape_tmdb_rating_badge"
                        android:drawablePadding="3dp"
                        android:paddingStart="8dp"
                        android:paddingTop="3dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="3dp"
                        android:textColor="#0F141A"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone"
                        tools:text="★ 8.6"
                        tools:visibility="visible" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tmdbMeta"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:textColor="#C8D2DC"
                        android:textSize="13sp"
                        tools:text="剧集 · 2023" />

                </androidx.appcompat.widget.LinearLayoutCompat>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tmdbGenres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#9AA7B4"
                    android:textSize="12sp"
                    android:visibility="gone"
                    tools:text="剧情 · 动作 · 奇幻"
                    tools:visibility="visible" />

            </androidx.appcompat.widget.LinearLayoutCompat>

        </androidx.appcompat.widget.LinearLayoutCompat>

    </FrameLayout>

    <!-- 评分展示区域 -->
    <com.google.android.flexbox.FlexboxLayout
        android:id="@+id/tmdbRatingsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:alignItems="flex_start"
        app:flexDirection="row"
        app:flexWrap="wrap" />

    <!-- 简介 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbOverview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.2"
        android:maxLines="4"
        android:textColor="#C8D2DC"
        android:textSize="13sp"
        android:visibility="gone"
        tools:text="王林是一个普通的少年……"
        tools:visibility="visible" />

    <HorizontalScrollView
        android:id="@+id/tmdbActionsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="false"
        android:overScrollMode="never"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:scrollbars="none">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/tmdbActions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tmdbChangeSource"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:minWidth="72dp"
                android:text="@string/play_change"
                android:textAllCaps="false"
                android:textColor="@color/tmdb_action_button_text"
                android:textSize="13sp"
                app:backgroundTint="@color/tmdb_action_button_bg"
                app:cornerRadius="20dp"
                app:strokeColor="@color/tmdb_action_button_stroke"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tmdbKeep"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:minWidth="72dp"
                android:text="@string/keep"
                android:textAllCaps="false"
                android:textColor="@color/tmdb_action_button_text"
                android:textSize="13sp"
                app:backgroundTint="@color/tmdb_action_button_bg"
                app:cornerRadius="20dp"
                app:strokeColor="@color/tmdb_action_button_stroke"
                app:strokeWidth="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/tmdbRematch"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="10dp"
                android:minWidth="88dp"
                android:text="@string/detail_tmdb_rematch"
                android:textAllCaps="false"
                android:textColor="@color/tmdb_action_button_text"
                android:textSize="13sp"
                app:backgroundTint="@color/tmdb_action_button_bg"
                app:cornerRadius="20dp"
                app:strokeColor="@color/tmdb_action_button_stroke"
                app:strokeWidth="1dp" />

        </androidx.appcompat.widget.LinearLayoutCompat>

    </HorizontalScrollView>

    <!-- 站源/线路/选集容器（移到演员上方） -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/tmdbPlaybackControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="vertical" />

    <!-- 演员标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbCastLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_cast_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 演员横向滚动 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbCast"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 主创团队标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbCrewLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_crew_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 主创团队横向滚动 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbCrew"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 剧照标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbPhotosLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_photos_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 剧照横向滚动 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbPhotos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 外部链接标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbExternalLinksLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_external_links_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 外部链接容器 -->
    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/tmdbExternalLinks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:visibility="gone" />

    <!-- 猜你喜欢标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbRecommendationsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_recommendations_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- 猜你喜欢横向滚动 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbRecommendations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 个性推荐 · TMDB -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbPersonalTmdbRecommendationsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_personal_recommendations_tmdb_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbPersonalTmdbRecommendations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 个性推荐 · 豆瓣 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbPersonalDoubanRecommendationsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_personal_recommendations_douban_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbPersonalDoubanRecommendations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- 个性推荐 · 智能 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbPersonalAiRecommendationsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_personal_recommendations_ai_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tmdbPersonalAiRecommendations"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    <!-- OMDB 多来源评分标题 -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tmdbOmdbRatingsLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/tmdb_ratings_label"
        android:textColor="@android:color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        android:visibility="gone"
        tools:visibility="visible" />

    <!-- OMDB 多来源评分容器（IMDb / 烂番茄 / Metacritic 等） -->
    <HorizontalScrollView
        android:id="@+id/tmdbOmdbRatingsScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:scrollbars="none"
        android:visibility="gone">

        <androidx.appcompat.widget.LinearLayoutCompat
            android:id="@+id/tmdbOmdbRatings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal" />

    </HorizontalScrollView>

    <!-- TMDB 水印 + 分隔 -->
    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginBottom="4dp"
        android:alpha="0.5"
        android:text="@string/tmdb_powered_by"
        android:textColor="#6B7785"
        android:textSize="10sp" />

</androidx.appcompat.widget.LinearLayoutCompat>
