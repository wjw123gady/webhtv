<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/text"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="8"
        android:background="@drawable/selector_custom_csp_item"
        android:clickable="true"
        android:ellipsize="end"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="start|center_vertical"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:singleLine="true"
        android:textColor="#202124"
        android:textSize="13sp"
        tools:text="https://gh-proxy.com/" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/remove"
        style="@style/Widget.WebHTV.LightDialog.Button.Outlined"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:layout_weight="2"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:text="@string/setting_github_proxy_remove"
        android:textColor="#202124"
        android:textSize="13sp"
        app:cornerRadius="8dp"
        app:iconPadding="0dp"
        app:strokeColor="#DADCE0" />

</androidx.appcompat.widget.LinearLayoutCompat>
