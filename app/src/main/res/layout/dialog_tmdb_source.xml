<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

<androidx.appcompat.widget.LinearLayoutCompat
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Helper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_enable_tip"
        android:paddingBottom="16dp" />

    <!-- API Key 输入框 -->
    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_api_key_label"
        android:paddingBottom="8dp" />

    <com.google.android.material.textfield.TextInputEditText
        style="@style/Widget.WebHTV.LightDialog.Input"
        android:id="@+id/apiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_tmdb_api_key_hint"
        android:inputType="textVisiblePassword"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Helper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_api_key_tip"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_language_label"
        android:paddingBottom="8dp" />

    <com.google.android.material.textfield.TextInputEditText
        style="@style/Widget.WebHTV.LightDialog.Input"
        android:id="@+id/languageInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_tmdb_language_hint"
        android:inputType="text"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_api_host_label"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.textfield.TextInputEditText
        style="@style/Widget.WebHTV.LightDialog.Input"
        android:id="@+id/apiHostInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_tmdb_api_host_hint"
        android:inputType="textUri"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_image_host_label"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.textfield.TextInputEditText
        style="@style/Widget.WebHTV.LightDialog.Input"
        android:id="@+id/imageHostInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_tmdb_image_host_hint"
        android:inputType="textUri"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <!-- OMDb API Key 输入框（可选） -->
    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_omdb_api_key_label"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.textfield.TextInputEditText
        style="@style/Widget.WebHTV.LightDialog.Input"
        android:id="@+id/omdbApiKeyInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/dialog_omdb_api_key_hint"
        android:inputType="textVisiblePassword"
        android:maxLines="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp" />

    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Helper"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_omdb_api_key_tip"
        android:paddingTop="4dp"
        android:paddingBottom="16dp" />

    <!-- 启用站点规则 -->
    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_enabled_sites_label"
        android:paddingTop="16dp"
        android:paddingBottom="8dp" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/enabledChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="4dp" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Widget.WebHTV.LightDialog.Input"
            android:id="@+id/ruleInput"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="@string/dialog_tmdb_add_rule_hint"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.WebHTV.LightDialog.Button.Tonal"
            android:id="@+id/add"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:minWidth="64dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/dialog_tmdb_add"
            android:textAllCaps="false"
            android:textSize="13sp" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <!-- 排除站点（黑名单） -->
    <com.google.android.material.textview.MaterialTextView
        style="@style/Widget.WebHTV.LightDialog.Label"
        android:id="@+id/disabledLabel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/dialog_tmdb_disabled_sites_label"
        android:textColor="#B3261E"
        android:paddingTop="12dp"
        android:paddingBottom="8dp"
        android:visibility="gone" />

    <com.google.android.material.chip.ChipGroup
        android:id="@+id/disabledChips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:chipSpacingHorizontal="8dp"
        app:chipSpacingVertical="4dp"
        android:visibility="gone" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/disabledInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <com.google.android.material.textfield.TextInputEditText
            style="@style/Widget.WebHTV.LightDialog.Input"
            android:id="@+id/disabledRuleInput"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="@string/dialog_tmdb_add_disabled_rule_hint"
            android:imeOptions="actionDone"
            android:inputType="text"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <com.google.android.material.button.MaterialButton
            style="@style/Widget.WebHTV.LightDialog.Button.Tonal"
            android:id="@+id/addDisabled"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="64dp"
            android:text="@string/dialog_tmdb_add"
            android:textAllCaps="false"
            android:textSize="13sp" />

    </androidx.appcompat.widget.LinearLayoutCompat>

    <!-- 操作按钮 -->
    <com.google.android.material.button.MaterialButton
        style="@style/Widget.WebHTV.LightDialog.Button.Outlined"
        android:id="@+id/manage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/dialog_tmdb_site_manage"
        android:textAllCaps="false" />

    <com.google.android.material.button.MaterialButton
        style="@style/Widget.WebHTV.LightDialog.Button.Text"
        android:id="@+id/resetDefault"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/dialog_tmdb_reset_default"
        android:textAllCaps="false" />

</androidx.appcompat.widget.LinearLayoutCompat>

</ScrollView>
