<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Selected state (current site) -->
    <item android:color="#1976D2" android:state_selected="true" />
    <!-- Focused/pressed states -->
    <item android:color="#D2E3FC" android:state_focused="true" />
    <item android:color="#D2E3FC" android:state_pressed="true" />
