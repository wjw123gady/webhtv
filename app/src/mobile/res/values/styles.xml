<resources>

    <style name="Theme.Base" parent="Theme.Material3.DynamicColors.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.Splash" parent="Theme.Base">
        <item name="android:windowBackground">@drawable/mobile_startup_window_background</item>
    </style>

    <style name="Theme.App" parent="Theme.Base" />

    <style name="Theme.Crash" parent="Theme.Base">
        <item name="android:windowDisablePreview">true</item>
        <item name="android:windowBackground">@color/grey_700</item>
    </style>

    <style name="Control">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:textColor">@color/yellow</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">8dp</item>
    </style>

    <style name="ControlSheetTitle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">13dp</item>
        <item name="android:layout_marginBottom">7dp</item>
        <item name="android:textColor">@color/white_70</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="ControlSheetButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">34dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_marginEnd">7dp</item>
        <item name="android:background">@drawable/selector_control_sheet_button</item>
        <item name="android:gravity">center</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/selector_control_sheet_text</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="VideoActionButton" parent="Video.ContextText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:drawablePadding">2dp</item>
        <item name="android:gravity">center</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:shadowColor">@color/black_90</item>
        <item name="android:shadowDx">0</item>
        <item name="android:shadowDy">2</item>
        <item name="android:shadowRadius">4</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="ToolbarTextAppearance" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="ToolbarPopupTheme" parent="ThemeOverlay.Material3.Light">
        <item name="android:popupBackground">@drawable/shape_toolbar_popup</item>
        <item name="android:textColorPrimary">#18333A</item>
        <item name="android:textColorSecondary">#5D7278</item>
        <item name="android:colorControlNormal">#2D4C55</item>
        <item name="colorControlNormal">#2D4C55</item>
        <item name="colorSurface">#F2FFFFFF</item>
        <item name="colorOnSurface">#18333A</item>
        <item name="colorOnSurfaceVariant">#5D7278</item>
        <item name="popupMenuStyle">@style/ToolbarPopupMenu</item>
        <item name="android:popupMenuStyle">@style/ToolbarPopupMenu</item>
        <item name="textAppearanceLargePopupMenu">@style/ToolbarPopupTextAppearance</item>
        <item name="textAppearanceSmallPopupMenu">@style/ToolbarPopupTextAppearance</item>
        <item name="android:textAppearanceLargePopupMenu">@style/ToolbarPopupTextAppearance</item>
        <item name="android:textAppearanceSmallPopupMenu">@style/ToolbarPopupTextAppearance</item>
    </style>

    <style name="ToolbarPopupMenu" parent="Widget.AppCompat.PopupMenu.Overflow">
        <item name="android:popupBackground">@drawable/shape_toolbar_popup</item>
    </style>

    <style name="ToolbarPopupTextAppearance" parent="TextAppearance.AppCompat.Widget.PopupMenu.Large">
        <item name="android:textColor">#18333A</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="ToolbarWhiteText" parent="">
        <item name="actionMenuTextColor">@android:color/white</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>

</resources>
